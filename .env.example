# OneDocs managed provider (optional)
VITE_ONEDOCS_API_URL=
VITE_ONEDOCS_API_KEY=

# SiliconFlow Embedding API Token (for RAG text embedding)
# 免费注册获取: https://cloud.siliconflow.cn
VITE_SILICONFLOW_TOKEN=

# Qiniu S3 (for EasyYun PDF image extraction)
ONEDOCS_QINIU_S3_ACCESS_KEY=
ONEDOCS_QINIU_S3_SECRET_KEY=
ONEDOCS_QINIU_S3_BUCKET=onedocsinput
ONEDOCS_QINIU_S3_REGION=cn-north-1
ONEDOCS_QINIU_S3_ENDPOINT=https://onedocsinput.s3.cn-north-1.qiniucs.com
ONEDOCS_QINIU_S3_PUBLIC_DOMAIN=http://onedocsinput.ijune.cn
